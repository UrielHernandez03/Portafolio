---
import type { ProjectData } from '../data/projectsData';

interface Props {
  project?: ProjectData;
}

const { project } = Astro.props;
const modules = project?.modules || [];
---

<section id="modulos" class="section modules-section">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-label">// MÓDULOS PRINCIPALES</div>
      <h2 class="section-title">Ecosistema <span class="gradient-text">Modular</span></h2>
      <p class="section-subtitle">
        {project?.title || 'Este proyecto'} está compuesto por múltiples módulos que operan de forma independiente y se integran perfectamente.
      </p>
    </div>

    <div class="modules-grid">
    </div>
  </div>
</section>

<style>
  .modules-section {
    background-color: var(--bg-secondary);
  }

  .modules-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .modules-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .modules-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    
    /* Center the last card if it's alone on the last row */
    .module-card:last-child {
      grid-column: 2;
    }
  }

  .module-card {
    position: relative;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .card-top-border {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--mod-accent);
  }

  .module-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px rgba(var(--mod-accent-rgb), 0.15);
    border-color: rgba(var(--mod-accent-rgb), 0.3);
  }

  .module-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .module-icon {
    font-size: 1.5rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--mod-accent-rgb), 0.1);
    border: 1px solid rgba(var(--mod-accent-rgb), 0.2);
    border-radius: 50%;
  }

  .module-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0;
    color: #fff;
  }

  .module-desc {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 0;
    margin-bottom: 1.5rem;
    line-height: 1.4;
  }

  .module-features {
    list-style: none;
    padding: 0;
    margin: auto 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .module-features li {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.8);
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .module-features li::before {
    content: "";
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--mod-accent);
    margin-top: 0.4rem;
    flex-shrink: 0;
  }
</style>
