---
---

<section id="modulos" class="section modules-section">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-label">// MÓDULOS ERP</div>
      <h2 class="section-title">Sistema <span class="gradient-text">Empresarial Completo</span></h2>
      <p class="section-subtitle">
        Una solución integral compuesta por 7 módulos principales diseñados para operar de forma
        autónoma o interconectada a través de microservicios.
      </p>
    </div>

    <div class="modules-grid">
      <!-- 1. Recursos Humanos -->
      <div class="module-card glass reveal reveal-delay-1" style="--mod-accent: #6366f1; --mod-accent-rgb: 99, 102, 241;">
        <div class="card-top-border"></div>
        <div class="module-header">
          <div class="module-icon">👥</div>
          <h3 class="module-title">Recursos Humanos</h3>
        </div>
        <p class="module-desc">Gestión integral del capital humano y nómina</p>
        <ul class="module-features">
          <li>Expedientes digitales</li>
          <li>Control de incidencias</li>
          <li>Documentación y vencimientos</li>
          <li>Estructura organizacional</li>
        </ul>
      </div>

      <!-- 2. Inventarios y Almacén -->
      <div class="module-card glass reveal reveal-delay-2" style="--mod-accent: #8b5cf6; --mod-accent-rgb: 139, 92, 246;">
        <div class="card-top-border"></div>
        <div class="module-header">
          <div class="module-icon">📦</div>
          <h3 class="module-title">Inventarios y Almacén</h3>
        </div>
        <p class="module-desc">Control total de productos y logística</p>
        <ul class="module-features">
          <li>Catálogo de productos y categorías</li>
          <li>Zonas de almacén por sucursal</li>
          <li>Recetas y despieces</li>
          <li>Órdenes de producción</li>
        </ul>
      </div>

      <!-- 3. Compras y Proveedores -->
      <div class="module-card glass reveal reveal-delay-3" style="--mod-accent: #06b6d4; --mod-accent-rgb: 6, 182, 212;">
        <div class="card-top-border"></div>
        <div class="module-header">
          <div class="module-icon">🛒</div>
          <h3 class="module-title">Compras y Proveedores</h3>
        </div>
        <p class="module-desc">Flujo completo de adquisiciones</p>
        <ul class="module-features">
          <li>Órdenes de compra</li>
          <li>Recepción de mercancía</li>
          <li>Evaluación de calidad</li>
          <li>Catálogo de proveedores</li>
        </ul>
      </div>

      <!-- 4. Finanzas y Tesorería -->
      <div class="module-card glass reveal reveal-delay-4" style="--mod-accent: #10b981; --mod-accent-rgb: 16, 185, 129;">
        <div class="card-top-border"></div>
        <div class="module-header">
          <div class="module-icon">💰</div>
          <h3 class="module-title">Finanzas y Tesorería</h3>
        </div>
        <p class="module-desc">Contabilidad y control financiero</p>
        <ul class="module-features">
          <li>Cuentas contables e impuestos</li>
          <li>Caja chica y arqueos</li>
          <li>Cuentas por cobrar</li>
          <li>Estados de cuenta</li>
        </ul>
      </div>

      <!-- 5. Activos Fijos -->
      <div class="module-card glass reveal reveal-delay-5" style="--mod-accent: #f59e0b; --mod-accent-rgb: 245, 158, 11;">
        <div class="card-top-border"></div>
        <div class="module-header">
          <div class="module-icon">🏗️</div>
          <h3 class="module-title">Activos Fijos</h3>
        </div>
        <p class="module-desc">Registro, depreciación y mantenimiento</p>
        <ul class="module-features">
          <li>Registro y clasificación</li>
          <li>Códigos QR de rastreo</li>
          <li>Depreciación automática</li>
          <li>Tickets de mantenimiento</li>
        </ul>
      </div>

      <!-- 6. Punto de Venta -->
      <div class="module-card glass reveal reveal-delay-1" style="--mod-accent: #f43f5e; --mod-accent-rgb: 244, 63, 94;">
        <div class="card-top-border"></div>
        <div class="module-header">
          <div class="module-icon">🍽️</div>
          <h3 class="module-title">Punto de Venta</h3>
        </div>
        <p class="module-desc">Operaciones de restaurante en tiempo real</p>
        <ul class="module-features">
          <li>Zonas y mesas</li>
          <li>Órdenes de cocina</li>
          <li>Gestión de turnos</li>
          <li>Arqueo y corte de caja</li>
        </ul>
      </div>

      <!-- 7. Seguridad y Admin -->
      <div class="module-card glass reveal reveal-delay-2" style="--mod-accent: #64748b; --mod-accent-rgb: 100, 116, 139;">
        <div class="card-top-border"></div>
        <div class="module-header">
          <div class="module-icon">🔐</div>
          <h3 class="module-title">Seguridad y Admin</h3>
        </div>
        <p class="module-desc">Control de acceso y multi-sucursal</p>
        <ul class="module-features">
          <li>Gestión multi-empresa</li>
          <li>RBAC (Roles y permisos)</li>
          <li>Matriz de permisos</li>
          <li>Gestión de usuarios</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .modules-section {
    background-color: var(--bg-secondary);
  }

  .modules-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 3rem;
  }

  @media (min-width: 768px) {
    .modules-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .modules-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    
    /* Center the last card if it's alone on the last row */
    .module-card:last-child {
      grid-column: 2;
    }
  }

  .module-card {
    position: relative;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    transition: all 0.3s ease;
    overflow: hidden;
  }

  .card-top-border {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--mod-accent);
  }

  .module-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 40px rgba(var(--mod-accent-rgb), 0.15);
    border-color: rgba(var(--mod-accent-rgb), 0.3);
  }

  .module-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .module-icon {
    font-size: 1.5rem;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--mod-accent-rgb), 0.1);
    border: 1px solid rgba(var(--mod-accent-rgb), 0.2);
    border-radius: 50%;
  }

  .module-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0;
    color: #fff;
  }

  .module-desc {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
    margin-top: 0;
    margin-bottom: 1.5rem;
    line-height: 1.4;
  }

  .module-features {
    list-style: none;
    padding: 0;
    margin: auto 0 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .module-features li {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.8);
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .module-features li::before {
    content: "";
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--mod-accent);
    margin-top: 0.4rem;
    flex-shrink: 0;
  }
</style>
