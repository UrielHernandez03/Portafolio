---
---

<section id="hero" class="hero">
  <div class="orbs">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>
  
  <div class="hero-content">
    <div class="animate-1">
      <span class="tag">&lt;/&gt; Desarrollador Full-Stack</span>
    </div>
    
    <h1 class="animate-2">
      <span class="greeting">Hola, soy</span><br />
      <span class="name gradient-text">Uriel Hernández</span>
    </h1>
    
    <p class="subtitle animate-3">
      Desarrollador Full-Stack especializado en arquitecturas de microservicios, sistemas ERP y aplicaciones empresariales de alto rendimiento.
    </p>
    
    <div class="actions animate-4">
      <a href="#proyecto" class="btn btn-primary">
        Ver Proyecto <span class="arrow">↓</span>
      </a>
      <a href="#contacto" class="btn btn-outline">
        Contacto
      </a>
    </div>
  </div>
  
  <a href="#proyecto" class="scroll-indicator" aria-label="Scroll down">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="chevron"><polyline points="6 9 12 15 18 9"></polyline></svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 0 2rem;
    background-color: var(--bg-primary, #07070d);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-size: 70px 70px;
    background-image: 
      linear-gradient(to right, rgba(99, 102, 241, 0.06) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(99, 102, 241, 0.06) 1px, transparent 1px);
    background-position: center center;
    z-index: 1;
    animation: gridMove 20s linear infinite;
    mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent);
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 20%, black 80%, transparent);
  }

  @keyframes gridMove {
    0% { transform: translateY(0); }
    100% { transform: translateY(70px); }
  }

  .orbs {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.6;
    animation: float 10s ease-in-out infinite;
  }

  .orb-1 {
    top: 10%;
    left: 20%;
    width: 300px;
    height: 300px;
    background: rgba(99, 102, 241, 0.4);
    animation-delay: 0s;
    animation-duration: 12s;
  }

  .orb-2 {
    bottom: 20%;
    right: 15%;
    width: 400px;
    height: 400px;
    background: rgba(139, 92, 246, 0.3);
    animation-delay: -3s;
    animation-duration: 15s;
  }

  .orb-3 {
    top: 40%;
    left: 60%;
    width: 250px;
    height: 250px;
    background: rgba(6, 182, 212, 0.3);
    animation-delay: -6s;
    animation-duration: 14s;
  }

  @keyframes float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
  }

  .hero-content {
    position: relative;
    z-index: 10;
    max-width: 800px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tag {
    display: inline-block;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    background: rgba(99, 102, 241, 0.1);
    border: 1px solid rgba(99, 102, 241, 0.2);
    color: var(--color-primary, #6366f1);
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.875rem;
    margin-bottom: 2rem;
  }

  h1 {
    font-family: var(--font-sans, 'Inter', sans-serif);
    margin: 0 0 1.5rem 0;
    line-height: 1.1;
  }

  .greeting {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--text-secondary, #a1a1aa);
  }

  .name {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    display: block;
    margin-top: 0.5rem;
  }

  .subtitle {
    color: var(--text-secondary, #a1a1aa);
    font-size: clamp(1rem, 2vw, 1.15rem);
    max-width: 600px;
    margin: 0 auto 2.5rem auto;
    line-height: 1.6;
    font-family: var(--font-sans, 'Inter', sans-serif);
  }

  .actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-family: var(--font-sans, 'Inter', sans-serif);
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    font-size: 1rem;
  }

  .btn-primary {
    background: var(--color-primary, #6366f1);
    color: white;
    border: 1px solid transparent;
  }

  .btn-primary:hover {
    background: transparent;
    border-color: var(--color-primary, #6366f1);
    color: var(--color-primary, #6366f1);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.4);
  }

  .btn-outline {
    background: transparent;
    color: var(--text-primary, #ffffff);
    border: 1px solid var(--border-glass, rgba(255,255,255,0.1));
  }

  .btn-outline:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }
  
  .arrow {
    margin-left: 0.5rem;
    transition: transform 0.3s ease;
  }

  .btn-primary:hover .arrow {
    transform: translateY(3px);
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--text-secondary, #a1a1aa);
    z-index: 10;
    animation: bounce 2s infinite;
    transition: color 0.3s ease;
  }

  .scroll-indicator:hover {
    color: var(--text-primary, #ffffff);
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translate(-50%, 0); }
    40% { transform: translate(-50%, -10px); }
    60% { transform: translate(-50%, -5px); }
  }

  /* Entrance animations */
  .animate-1 { animation: fadeInUp 0.8s ease backwards 0.1s; }
  .animate-2 { animation: fadeInUp 0.8s ease backwards 0.3s; }
  .animate-3 { animation: fadeInUp 0.8s ease backwards 0.5s; }
  .animate-4 { animation: fadeInUp 0.8s ease backwards 0.7s; }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
