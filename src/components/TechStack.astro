---
---

<section id="stack" class="section">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-label">// STACK TECNOLÓGICO</div>
      <h2 class="section-title">Tecnologías & <span class="gradient-text">Herramientas</span></h2>
      <p class="section-subtitle">
        El ecosistema de LandySystem está construido con tecnologías modernas y robustas,
        optimizadas para escalabilidad, rendimiento y experiencia de usuario.
      </p>
    </div>

    <div class="stack-grid">
      <!-- Backend Column -->
      <div class="stack-card glass backend-card reveal reveal-delay-1">
        <div class="card-header">
          <div class="header-icon">⚙️</div>
          <div class="header-info">
            <h3 class="category-name">Backend (Microservicios)</h3>
            <p class="category-desc">Arquitectura escalable y distribuida</p>
          </div>
        </div>
        <div class="tech-grid">
          <span class="tech-pill">Moleculer</span>
          <span class="tech-pill">Node.js</span>
          <span class="tech-pill">PostgreSQL</span>
          <span class="tech-pill">MongoDB</span>
          <span class="tech-pill">JWT</span>
          <span class="tech-pill">bcrypt</span>
          <span class="tech-pill">AWS S3</span>
          <span class="tech-pill">AWS Textract</span>
          <span class="tech-pill">PDFKit</span>
          <span class="tech-pill">XLSX</span>
          <span class="tech-pill">Multer</span>
          <span class="tech-pill">QRCode</span>
          <span class="tech-pill">Postmark</span>
        </div>
      </div>

      <!-- Frontend Admin Column -->
      <div class="stack-card glass frontend-card reveal reveal-delay-2">
        <div class="card-header">
          <div class="header-icon">💻</div>
          <div class="header-info">
            <h3 class="category-name">Frontend Admin (UI)</h3>
            <p class="category-desc">Interfaz de administración y gestión</p>
          </div>
        </div>
        <div class="tech-grid">
          <span class="tech-pill">React 19</span>
          <span class="tech-pill">Vite</span>
          <span class="tech-pill">Material UI v7</span>
          <span class="tech-pill">Emotion</span>
          <span class="tech-pill">Zod</span>
          <span class="tech-pill">Chart.js</span>
          <span class="tech-pill">jsPDF</span>
          <span class="tech-pill">ExcelJS</span>
          <span class="tech-pill">react-webcam</span>
          <span class="tech-pill">@zxing/browser</span>
          <span class="tech-pill">react-signature-canvas</span>
        </div>
      </div>

      <!-- Frontend POS Column -->
      <div class="stack-card glass pos-card reveal reveal-delay-3">
        <div class="card-header">
          <div class="header-icon">🏪</div>
          <div class="header-info">
            <h3 class="category-name">Frontend POS</h3>
            <p class="category-desc">Punto de venta y conexión local</p>
          </div>
        </div>
        <div class="tech-grid">
          <span class="tech-pill">React</span>
          <span class="tech-pill">Node.js Service</span>
          <span class="tech-pill">ESC/POS Protocol</span>
          <span class="tech-pill">Thermal Printer</span>
          <span class="tech-pill">Impresora Térmica</span>
          <span class="tech-pill">Hardware Integration</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  @media (min-width: 992px) {
    .stack-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .stack-card {
    display: flex;
    flex-direction: column;
    padding: 2rem;
    position: relative;
    overflow: hidden;
    transition: var(--transition-base);
  }

  .backend-card {
    border-left: 3px solid var(--color-primary);
    --card-accent: var(--color-primary);
    --card-accent-rgb: 99, 102, 241;
  }

  .frontend-card {
    border-left: 3px solid var(--color-secondary);
    --card-accent: var(--color-secondary);
    --card-accent-rgb: 139, 92, 246;
  }

  .pos-card {
    border-left: 3px solid var(--color-accent);
    --card-accent: var(--color-accent);
    --card-accent-rgb: 6, 182, 212;
  }

  .stack-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(var(--card-accent-rgb), 0.15);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .header-icon {
    font-size: 2rem;
    background: rgba(var(--card-accent-rgb), 0.1);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
  }

  .category-name {
    font-size: 1.25rem;
    margin: 0 0 0.25rem 0;
    color: var(--card-accent);
  }

  .category-desc {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  .tech-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tech-pill {
    padding: 0.4rem 0.9rem;
    font-size: 0.82rem;
    font-family: var(--font-mono);
    color: #fff;
    background: rgba(var(--card-accent-rgb), 0.05);
    border: 1px solid rgba(var(--card-accent-rgb), 0.2);
    border-radius: 100px;
    transition: var(--transition-fast);
    cursor: default;
  }

  .tech-pill:hover {
    background: rgba(var(--card-accent-rgb), 0.15);
    border-color: var(--card-accent);
    box-shadow: 0 0 10px rgba(var(--card-accent-rgb), 0.3);
    transform: translateY(-2px);
  }
</style>
