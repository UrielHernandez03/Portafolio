---
/**
 * Projects.astro — Sección de proyectos del portafolio.
 * Diseño extensible: para agregar un proyecto, solo agrega otro objeto al array `projects`.
 */

interface ProjectLink {
  label: string;
  url: string;
  icon: string;
}

interface ProjectImage {
  src: string;
  alt: string;
  label: string;
  url: string;
}

interface Project {
  id: string;
  title: string;
  subtitle: string;
  description: string;
  features: string[];
  tags: string[];
  images: ProjectImage[];
  links: ProjectLink[];
  accentColor: string;
  accentGlow: string;
}

const projects: Project[] = [
  {
    id: 'landysystem',
    title: 'LandySystem',
    subtitle: 'ERP & Punto de Venta — Plataforma Empresarial',
    description:
      'Plataforma ERP/Punto de Venta robusta y modular diseñada con arquitectura de microservicios y múltiples interfaces de usuario. Gestiona integralmente recursos humanos, finanzas, inventarios, compras, calidad, activos fijos y operaciones de punto de venta para restaurante/carnicería.',
    features: [
      '7+ módulos ERP integrados',
      'Arquitectura de microservicios con Moleculer',
      'Integración de hardware (impresoras térmicas ESC/POS)',
      'Sistema paperless con OCR (AWS Textract)',
      'Control multi-sucursal con RBAC',
      'Generación de reportes PDF/Excel en tiempo real',
    ],
    tags: ['React 19', 'Node.js', 'Moleculer', 'PostgreSQL', 'MongoDB', 'Material UI', 'Vite', 'AWS', 'JWT'],
    images: [
      {
        src: '/images/landysystem-dashboard.png',
        alt: 'LandySystem Dashboard — Panel administrativo ERP',
        label: 'Dashboard Admin',
        url: 'dev.landysystem.com.mx',
      },
      {
        src: '/images/landysystem-pos.png',
        alt: 'LandyPOS — Punto de Venta Restaurante',
        label: 'Punto de Venta',
        url: 'pos-dev.landysystem.com.mx',
      },
    ],
    links: [
      { label: 'Ver Dashboard', url: 'https://dev.landysystem.com.mx/', icon: '🖥️' },
      { label: 'Ver POS', url: 'https://pos-dev.landysystem.com.mx/', icon: '🏪' },
    ],
    accentColor: '#6366f1',
    accentGlow: 'rgba(99, 102, 241, 0.15)',
  },
  {
    id: 'historias-en-papel',
    title: 'Historias en Papel',
    subtitle: 'Plataforma de Gestión de Eventos (SISTWEB)',
    description:
      'Expansión y optimización de plataforma de gestión de eventos exclusiva. Se implementó una arquitectura de carga masiva en Excel para el registro simultáneo de múltiples acompañantes, integrándose sin causar regresiones y manteniendo la UX y validaciones corporativas.',
    features: [
      'Algoritmo de extracción segura de archivos (.xlsx) con PHP y asociación relacional',
      'Edición no destructiva de plantillas conservando Data Validation y estilos (PhpSpreadsheet)',
      'Normalización robusta de strings y estrategia de fallbacks para evitar corrupción de datos',
      'Inyección dinámica de datos y renderizado en tiempo real con DataTables',
      'Desarrollo retrocompatible protegiendo envíos masivos y generación de QR',
      'Manejo de entornos seguros con Git y adaptación a código legacy sin fricciones'
    ],
    tags: ['PHP', 'JavaScript', 'HTML', 'DataTables', 'PhpSpreadsheet', 'Git'],
    images: [
      {
        src: '/images/historias-en-papel.webp',
        alt: 'Dashboard de Gestión de Eventos - Historias en Papel',
        label: 'Panel de Eventos',
        url: 'www.historiasenpapeldigital.com',
      }
    ],
    links: [
      { label: 'Sistema Digital', url: 'https://www.historiasenpapeldigital.com/', icon: '🌐' },
      { label: 'Sitio Corporativo', url: 'https://www.historiasenpapel.com/', icon: '🔗' },
    ],
    accentColor: '#3b82f6',
    accentGlow: 'rgba(59, 130, 246, 0.15)',
  },
  // ── Agrega más proyectos aquí ──
];
---

<section id="proyectos" class="section">
  <div class="container">
    <!-- Section Header -->
    <div class="section-header reveal">
      <span class="section-label">// PROYECTOS</span>
      <h2 class="section-title">Mis <span class="gradient-text">Proyectos</span></h2>
      <p class="section-subtitle">
        Soluciones de software desarrolladas de principio a fin con tecnologías modernas y arquitecturas escalables.
      </p>
    </div>

    <!-- Projects List -->
    <div class="projects-list">
      {projects.map((project, projectIndex) => (
        <article class="project-card reveal" id={`project-${project.id}`}>
          <!-- Glow decoration -->
          <div class="project-glow" style={`background: ${project.accentGlow};`}></div>

          <!-- Images Section -->
          <div class="project-images">
            {project.images.map((image, imgIndex) => (
              <a
                href={`https://${image.url}`}
                target="_blank"
                rel="noopener noreferrer"
                class={`browser-frame reveal reveal-delay-${imgIndex + 1}`}
              >
                <!-- Browser Chrome -->
                <div class="browser-chrome">
                  <div class="browser-dots">
                    <span class="dot dot-red"></span>
                    <span class="dot dot-yellow"></span>
                    <span class="dot dot-green"></span>
                  </div>
                  <div class="browser-url">
                    <svg class="lock-icon" viewBox="0 0 16 16" fill="none">
                      <path
                        d="M11.5 7V5a3.5 3.5 0 0 0-7 0v2M4 7h8a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V8a1 1 0 0 1 1-1z"
                        stroke="currentColor"
                        stroke-width="1.2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    <span>{image.url}</span>
                  </div>
                  <div class="browser-label">{image.label}</div>
                </div>
                <!-- Screenshot -->
                <div class="browser-viewport">
                  <img src={image.src} alt={image.alt} loading="lazy" />
                  <div class="image-overlay">
                    <span class="overlay-text">
                      Visitar sitio
                      <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                        <path
                          fill-rule="evenodd"
                          d="M5.22 14.78a.75.75 0 0 0 1.06 0l7.22-7.22v5.69a.75.75 0 0 0 1.5 0v-7.5a.75.75 0 0 0-.75-.75h-7.5a.75.75 0 0 0 0 1.5h5.69l-7.22 7.22a.75.75 0 0 0 0 1.06z"
                          clip-rule="evenodd"
                        />
                      </svg>
                    </span>
                  </div>
                </div>
              </a>
            ))}
          </div>

          <!-- Info Section -->
          <div class="project-info">
            <div class="project-badge">
              <span class="badge-dot" style={`background: ${project.accentColor};`}></span>
              Proyecto Destacado
            </div>

            <h3 class="project-title">
              <span class="gradient-text">{project.title}</span>
            </h3>
            <p class="project-subtitle">{project.subtitle}</p>

            <p class="project-description">{project.description}</p>

            <!-- Features -->
            <ul class="project-features">
              {project.features.map((feature) => (
                <li>
                  <svg class="check-icon" viewBox="0 0 20 20" fill="currentColor">
                    <path
                      fill-rule="evenodd"
                      d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <!-- Tags -->
            <div class="project-tags">
              {project.tags.map((tag) => (
                <span class="project-tag">{tag}</span>
              ))}
            </div>

            <!-- Links -->
            <div class="project-links">
              <a href={`/proyecto/${project.id}`} class="btn btn-primary">
                <span>📖</span>
                Leer Caso de Estudio
                <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                  <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                </svg>
              </a>
              {project.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-outline"
                >
                  <span>{link.icon}</span>
                  {link.label}
                  <svg viewBox="0 0 20 20" fill="currentColor" width="16" height="16">
                    <path
                      fill-rule="evenodd"
                      d="M5.22 14.78a.75.75 0 0 0 1.06 0l7.22-7.22v5.69a.75.75 0 0 0 1.5 0v-7.5a.75.75 0 0 0-.75-.75h-7.5a.75.75 0 0 0 0 1.5h5.69l-7.22 7.22a.75.75 0 0 0 0 1.06z"
                      clip-rule="evenodd"
                    />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Projects List ── */
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4xl);
  }

  /* ── Project Card ── */
  .project-card {
    position: relative;
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: var(--space-3xl);
    align-items: center;
    padding: var(--space-3xl);
    background: var(--bg-glass);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--border-glass);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: border-color var(--transition-base);
  }

  .project-card:hover {
    border-color: var(--border-glass-hover);
  }

  /* Glow */
  .project-glow {
    position: absolute;
    top: -100px;
    right: -100px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
    transition: opacity var(--transition-slow);
  }

  .project-card:hover .project-glow {
    opacity: 0.8;
  }

  /* ── Images ── */
  .project-images {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  /* Browser Frame */
  .browser-frame {
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--border-glass);
    background: #0c0c18;
    transition: all var(--transition-base);
    cursor: pointer;
    text-decoration: none;
  }

  .browser-frame:hover {
    border-color: var(--border-glass-hover);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4);
  }

  .browser-chrome {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding: 0.6rem 1rem;
    background: rgba(20, 20, 40, 0.9);
    border-bottom: 1px solid var(--border-glass);
  }

  .browser-dots {
    display: flex;
    gap: 6px;
    flex-shrink: 0;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }

  .browser-url {
    display: flex;
    align-items: center;
    gap: 6px;
    flex: 1;
    padding: 0.3rem 0.75rem;
    background: rgba(255, 255, 255, 0.04);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .lock-icon {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
    color: var(--color-success);
  }

  .browser-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-primary-light);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .browser-viewport {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9.5;
  }

  .browser-viewport img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top left;
    transition: transform 8s ease;
  }

  .browser-frame:hover .browser-viewport img {
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: rgba(7, 7, 13, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .browser-frame:hover .image-overlay {
    opacity: 1;
  }

  .overlay-text {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.6rem 1.2rem;
    background: var(--gradient-primary);
    border-radius: var(--radius-full);
    color: white;
    font-weight: 600;
    font-size: 0.85rem;
  }

  /* ── Info ── */
  .project-info {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .project-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    width: fit-content;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
  }

  .project-title {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
  }

  .project-subtitle {
    font-size: 1.05rem;
    color: var(--text-secondary);
    font-weight: 500;
    margin-bottom: var(--space-xs);
  }

  .project-description {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.75;
  }

  /* Features */
  .project-features {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin: var(--space-md) 0;
  }

  .project-features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm);
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .check-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--color-success);
    margin-top: 1px;
  }

  /* Tags */
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: var(--space-sm) 0;
  }

  .project-tag {
    padding: 0.3rem 0.7rem;
    font-size: 0.72rem;
    font-family: var(--font-mono);
    font-weight: 500;
    color: var(--color-primary-light);
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.18);
    border-radius: var(--radius-full);
    transition: all var(--transition-fast);
  }

  .project-tag:hover {
    background: rgba(99, 102, 241, 0.15);
    border-color: rgba(99, 102, 241, 0.35);
  }

  /* Links */
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .project-links .btn {
    font-size: 0.88rem;
  }

  .project-links .btn svg {
    transition: transform var(--transition-fast);
  }

  .project-links .btn:hover svg {
    transform: translate(2px, -2px);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .project-card {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
      padding: var(--space-2xl);
    }

    .project-images {
      order: -1;
    }

    .project-glow {
      top: -60px;
      right: -60px;
      width: 250px;
      height: 250px;
    }
  }

  @media (max-width: 640px) {
    .project-card {
      padding: var(--space-lg);
      border-radius: var(--radius-lg);
    }

    .browser-chrome {
      padding: 0.5rem 0.7rem;
    }

    .browser-label {
      display: none;
    }

    .project-links {
      flex-direction: column;
    }

    .project-links .btn {
      justify-content: center;
      width: 100%;
    }

    .project-title {
      font-size: 1.6rem;
    }
  }
</style>
