---
import type { ProjectData } from '../data/projectsData';

interface Props {
  project?: ProjectData;
}

const { project } = Astro.props;

// Default to a fallback if no project is provided (e.g. if rendered directly without props by mistake)
const title = project?.title || 'Plataforma LandySystem';
const subtitle = project?.subtitle || 'ERP y Punto de Venta diseñado para operaciones de alto rendimiento';
const description = project?.description || ['Descripción del proyecto.'];
const terminal = project?.terminal || { command: '', output: '' };
const stats = project?.stats || [];
---

<section id="proyecto" class="section">
  <div class="orb orb-primary" style="top: 20%; left: -10%;"></div>
  <div class="orb orb-secondary" style="bottom: 10%; right: -10%;"></div>
  
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">// PROYECTO DESTACADO</span>
      <h2 class="section-title">Plataforma <span class="gradient-text">{title}</span></h2>
      <p class="section-subtitle">{subtitle}</p>
    </div>

    <div class="overview-grid">
      <div class="overview-text glass reveal reveal-delay-1">
        {description.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>

      <div class="terminal-mockup glass-static reveal reveal-delay-2">
        <div class="terminal-header">
          <div class="terminal-dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <div class="terminal-title">bash - {project?.id || 'project'}</div>
        </div>
        <div class="terminal-body">
<pre><code>$ {terminal.command}

<span set:html={terminal.output}></span></code></pre>
        </div>
      </div>
    </div>

    <div class="stats-grid reveal reveal-delay-3">
      {stats.map((stat) => (
        <div class="stat-card glass">
          <span class="stat-icon">{stat.icon}</span>
          <h3 class="stat-value gradient-text">{stat.value}</h3>
          <p class="stat-label">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .overview-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  @media (min-width: 992px) {
    .overview-grid {
      grid-template-columns: 1fr 1fr;
      align-items: stretch;
    }
  }

  .overview-text {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.5rem;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-secondary, #94a3b8);
  }

  .terminal-mockup {
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background: rgba(0, 0, 0, 0.4);
  }

  .terminal-header {
    background: rgba(20, 20, 40, 0.8);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border-glass, rgba(255, 255, 255, 0.1));
  }

  .terminal-dots {
    display: flex;
    gap: 0.4rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background-color: #ff5f56; }
  .dot.yellow { background-color: #ffbd2e; }
  .dot.green { background-color: #27c93f; }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.85rem;
    color: var(--text-muted, #64748b);
  }

  .terminal-body {
    padding: 1.5rem;
    flex: 1;
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: 0.95rem;
    line-height: 1.6;
    color: #e2e8f0;
    overflow-x: auto;
  }

  .terminal-body pre {
    margin: 0;
  }

  .tech-tag {
    color: var(--color-accent, #06b6d4);
  }

  .status-running {
    color: #10b981;
  }
  
  .status-icon {
    display: inline-block;
    width: 20px;
  }

  .stats-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }

  .stat-card {
    flex: 1 1 200px;
    max-width: 300px;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(99, 102, 241, 0.15);
  }

  .stat-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    opacity: 0.9;
  }

  .stat-value {
    font-size: 3rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.9rem;
    color: var(--text-secondary, #94a3b8);
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0;
  }
</style>
